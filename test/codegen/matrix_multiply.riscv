  .option nopic
  .text
  .globl matmul_i32
matmul_i32:
  addi sp, sp, -96
  sd s0, 0(sp)
  sd s1, 8(sp)
  sd s2, 16(sp)
  sd s3, 24(sp)
  sd s4, 32(sp)
  sd s5, 40(sp)
  sd s6, 48(sp)
  sd s7, 56(sp)
  sd s8, 64(sp)
  sd s9, 72(sp)
  sd s10, 80(sp)
  sd s11, 88(sp)
  mv s0, a0
  mv s1, a1
  mv s2, a2
  mv s3, a3
  mv s4, a4
  mv s5, a5
  li s6, 0
.Lmatrix_multiply_row.0:
  bgeu s6, s3, .Lmatrix_multiply_end.5
  li s7, 0
.Lmatrix_multiply_col.1:
  bgeu s7, s4, .Lmatrix_multiply_next_row.4
  li s8, 0
  li s9, 0
.Lmatrix_multiply_inner.2:
  bgeu s8, s5, .Lmatrix_multiply_store.3
  mul s10, s6, s5
  add s10, s10, s8
  slli s10, s10, 2
  add s10, s1, s10
  lw t0, 0(s10)
  mul s11, s8, s4
  add s11, s11, s7
  slli s11, s11, 2
  add s11, s2, s11
  lw t1, 0(s11)
  mulw t2, t0, t1
  addw s9, s9, t2
  addi s8, s8, 1
  j .Lmatrix_multiply_inner.2
.Lmatrix_multiply_store.3:
  mul s10, s6, s4
  add s10, s10, s7
  slli s10, s10, 2
  add s10, s0, s10
  sw s9, 0(s10)
  addi s7, s7, 1
  j .Lmatrix_multiply_col.1
.Lmatrix_multiply_next_row.4:
  addi s6, s6, 1
  j .Lmatrix_multiply_row.0
.Lmatrix_multiply_end.5:
  ld s0, 0(sp)
  ld s1, 8(sp)
  ld s2, 16(sp)
  ld s3, 24(sp)
  ld s4, 32(sp)
  ld s5, 40(sp)
  ld s6, 48(sp)
  ld s7, 56(sp)
  ld s8, 64(sp)
  ld s9, 72(sp)
  ld s10, 80(sp)
  ld s11, 88(sp)
  addi sp, sp, 96
  li t0, 0
  mv a0, t0
  ret
