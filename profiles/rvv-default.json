      "implemented": [
        "matrix_pack_b",
        "matrix_multiply_packed_b"
      ],
      "rhs_layout": "packed_b[col * inner + k] equals original_b[k * cols + col]",
      "direct_rvv_policy": "per-output dot product with unit-stride vle32.v loads, vmul.vv, and vredsum.vs under e32,m1,ta,ma",
      "compiler_owned_pack_b": "matrix_pack_b packed_b, b, cols, inner; writes packed_b[col * inner + k] = b[k * cols + col] before packed-B RVV dot products"
    },
