        "lt",
        "le",
        "gt",
        "ge",
        "eq",
        "ne",
        "ult",
        "ule",
        "ugt",
        "uge"
      ],
      "direct_rvv_policy": "v0 compare/logical mask plus masked arithmetic; vector_masked_store uses predicated vse32.v with v0.t and preserves false lanes in memory; vector_masked_load uses masked vle32.v plus vmerge.vvm passthrough because the active policy is ta, ma; masked strided/indexed memory uses vlse32.v/vluxei32.v/vsse32.v/vsuxei32.v with v0.t and explicit passthrough merge for loads",
      "memory_consumers": [
        "vector_masked_load",
        "vector_masked_store",
        "vector_masked_strided_load",
        "vector_masked_indexed_load",
        "vector_masked_strided_store",
        "vector_masked_indexed_store"
      ]
    },
